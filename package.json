{
  "name": "petbot",
  "version": "8.5.0",
  "description": "",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "main": "dist/index.js",
  "scripts": {
    "tsc:server": "tsc -p tsconfig.server.json",
    "dev": "npm run tsc:server && node dist/src/deploy-commands.js && node dist/src/index.js",
    "dev:web": "cd apps/web && npm run dev",
    "build": "npm run tsc:server && npm run build:web",
    "build:server": "npm run tsc:server",
    "build:web": "cd apps/web && npm run build",
    "build:ci": "npm run build:web && npm run build:server",
    "start": "node dist/src/index.js",
    "start:web": "cd apps/web && npm run start",
    "test": "vitest --run",
    "test:ci": "vitest --run --silent",
    "test:watch": "vitest",
    "test:web": "cd apps/web && npm run test",
    "test:web:ci": "cd apps/web && npm run test:ci",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:web": "cd apps/web && npm run lint",
    "format": "prettier --write \"**/*.{js,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,json,md}\"",
    "tag": "git tag v$(node -p \"require('./package.json').version\") && git push origin v$(node -p \"require('./package.json').version\")",
    "release": "npm run build && npm run test && npm run tag",
    "prepare": "node ./scripts/prepare.js",
    "migrate:drizzle": "drizzle-kit migrate",
    "migrate:drizzle:status": "drizzle-kit status",
    "bearer:scan": "bearer scan . --severity critical,high,medium"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "discord.js": "^14.21.0",
    "dotenv": "^16.1.4",
    "drizzle-orm": "^1.0.0-beta.15-859cf75",
    "node-fetch": "^3.3.1",
    "pino": "^10.1.0",
    "pino-pretty": "^11.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24",
    "@types/node-fetch": "^2.6.13",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "drizzle-kit": "^1.0.0-beta.15-859cf75",
    "eslint": "^10.0.1",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.0.5",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "tar": "^7.5.7",
    "undici": "^6.24.0"
  }
}
