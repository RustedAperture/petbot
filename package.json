{
  "name": "petbot",
  "version": "8.8.1",
  "description": "",
  "type": "module",
  "packageManager": "npm@11.16.0",
  "workspaces": [
    "apps/web"
  ],
  "engines": {
    "node": ">=24",
    "npm": ">=11.10.0"
  },
  "main": "dist/index.js",
  "scripts": {
    "tsc:server": "tsc -p tsconfig.server.json",
    "dev": "npm run tsc:server && node dist/src/deploy-commands.js && node dist/src/index.js",
    "dev:web": "npm --workspace web run dev",
    "build": "npm run tsc:server && npm run build:web",
    "build:server": "npm run tsc:server",
    "build:web": "npm --workspace web run build",
    "build:ci": "npm run build:web && npm run build:server",
    "start": "node dist/src/index.js",
    "start:web": "npm --workspace web run start",
    "test": "vitest --run",
    "test:ci": "vitest --run --silent",
    "test:watch": "vitest",
    "test:web": "npm --workspace web run test",
    "test:web:ci": "npm --workspace web run test:ci",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:web": "npm --workspace web run lint",
    "format": "prettier --write \"**/*.{js,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,json,md}\"",
    "tag": "git tag v$(node -p \"require('./package.json').version\") && git push origin v$(node -p \"require('./package.json').version\")",
    "release": "npm run build && npm run test && npm run tag",
    "prepare": "node ./scripts/prepare.js",
    "migrate:drizzle": "drizzle-kit migrate",
    "migrate:drizzle:status": "drizzle-kit status",
    "bearer:scan": "bearer scan . --severity critical,high,medium"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@libsql/client": "^0.17.3",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^1.0.0-rc.3",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "node-fetch": "^3.3.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "@types/node-fetch": "^2.6.13",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "drizzle-kit": "^1.0.0-rc.3",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.7"
  },
  "overrides": {
    "tar": "^7.5.15",
    "undici": "^7.25.0"
  }
}
